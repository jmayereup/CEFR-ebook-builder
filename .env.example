OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_BACKEND_PROVIDER=pocketbase
VITE_POCKETBASE_URL=your_url_without_api_ending_here

# PocketBase Admin credentials (used for schema typegen and server-side operations)
POCKETBASE_ADMIN_EMAIL=your_pocketbase_admin_email_here
POCKETBASE_ADMIN_PASSWORD=your_pocketbase_admin_password_here

# Deployment configuration
DEPLOY_SERVER_IP=your_server_ip_here
DEPLOY_SERVER_USER=your_server_user_here
DEPLOY_SERVER_PATH=your_server_path_here
DEPLOY_SERVICE_NAME=your_service_name_here
