  file_change {
    absolute_path_uri: "file:///server.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import express from \'express\';\nimport path from \'path\';\nimport dotenv from \'dotenv\';\nimport { GoogleGenAI, Type } from \'@google/genai\';\nimport { createServer as createViteServer } from \'vite\';\n\ndotenv.config();\n\nconst app = express();\nconst PORT = 3000;\n\napp.use(express.json({ limit: \'10mb\' }));\n\n// Lazy initializer for Gemini client to prevent crashes if key is initially empty\nlet aiClient: GoogleGenAI | null = null;\nfunction getAiClient(): GoogleGenAI {\n  if (!aiClient) {\n    const apiKey = process.env.GEMINI_API_KEY;\n    if (!apiKey) {\n      throw new Error(\'GEMINI_API_KEY is not defined. Please add it via the Settings > Secrets menu.\');\n    }\n    aiClient = new GoogleGenAI({\n      apiKey,\n      httpOptions: {\n        headers: {\n          \'User-Agent\': \'aistudio-build\',\n        },\n      },\n    });\n  }\n  return aiClient;\n}\n\n// Endpoint to generate a stories chapter\napp.post(\'/api/stories/generate-chapter\', async (req, res) => {\n  try {\n    const {\n      language,\n      cefrLevel,\n      genre,\n      totalChapters,\n      chapterNumber,\n      storyTitle,\n      previousChapters,\n      promptNotes,\n    } = req.body;\n\n    if (!language || !cefrLevel || !genre || !totalChapters || !chapterNumber) {\n      return res.status(400).json({ error: \'Missing required configuration parameters.\' });\n    }\n\n    const ai = getAiClient();\n    const isFirstChapter = chapterNumber === 1;\n\n    let systemInstruction = `You are an expert bilingual linguist and a professional story writer. \nYour target is to generate a short story segment (chapter) tailored for learners studying ${language} at the CEFR difficulty level of ${cefrLevel}.\nThe narrative style must strictly adhere to the ${cefrLevel} CEFR guidelines:\n- A1: Extremely basic, short sentences, simple vocab, present tense only, very repetitive, easy to read.\n- A2: Elementary, basic connectors, simple past/present tenses, routine situations, concrete vocabulary.\n- B1: Intermediate, moderate structures, complex sentences with basic clauses, narratives of events, feelings, daily experiences.\n- B2: Upper-Intermediate, rich vocabulary, clear descriptions of complex situations, varied idiomatic expressions, nuanced narrative structures.\n- C1: Advanced, elaborate descriptions, high stylistic expression, diverse grammar structures, metaphors, natural, highly expressive target language.\n- C2: Mastery, expert-level native text, highly advanced wordplays, idiomatic mastery.\n\nThe chapter must be approximately 350 to 500 words long.\nYou must also select and extract 5 to 10 key vocabulary terms from this chapter. For each term, provide its part of speech, a clear English meaning/definition, and its usage context (such as the sentence it occurs in).`;\n\n    let prompt = \'\';\n    let responseSchema: any = {};\n\n    if (isFirstChapter) {\n      responseSchema = {\n        type: Type.OBJECT,\n        properties: {\n          storyTitle: {\n            type: Type.STRING,\n            description: `The overarching title for the entire story, written in beautiful ${language} appropriate for ${cefrLevel} level.`,\n          },\n          chapterTitle: {\n            type: Type.STRING,\n            description: `The specific title for Chapter 1, written in ${language}.`,\n          },\n          content: {\n            type: Type.STRING,\n            description: `The story narrative of Chapter 1. Approximately 350-500 words written strictly in ${language} at ${cefrLevel} level.`,\n          },\n          vocabulary: {\n            type: Type.ARRAY,\n            items: {\n              type: Type.OBJECT,\n              properties: {\n                word: { type: Type.STRING, description: \'The terms, verbs, or expressions.\' },\n                partOfSpeech: { type: Type.STRING, description: \'Noun, Verb, Adjective, Idiom, etc.\' },\n                definition: { type: Type.STRING, description: \'English translation or explanation of the term.\' },\n                contextSentence: { type: Type.STRING, description: \'The exact sentence where it appears, or a custom illustrative sentence.\' },\n              },\n              required: [\'word\', \'partOfSpeech\', \'definition\', \'contextSentence\'],\n            },\n            description: \'5 to 10 interesting or key terms from Chapter 1 for review.\',\n          },\n        },\n        required: [\'storyTitle\', \'chapterTitle\', \'content\', \'vocabulary\'],\n      };\n\n      prompt = `Start a brand new story written in ${language} at the CEFR ${cefrLevel} difficulty level.\nGenre of the story: ${genre}\nExpected total number of chapters: ${totalChapters}\nChapter details: This is Chapter 1 of ${totalChapters}.\n${promptNotes ? `Incorporate these user ideas/characters/setting: \"${promptNotes}\"` : \'Choose an engaging start fitting the genre and level.\'}\n\nBased on these guidelines, invent an overarching story title, a chapter title, the story chapter content (approx. 400 words), and extract the key terms.`;\n    } else {\n      responseSchema = {\n        type: Type.OBJECT,\n        properties: {\n          chapterTitle: {\n            type: Type.STRING,\n            description: `The specific title for Chapter ${chapterNumber}, written in ${language}.`,\n          },\n          content: {\n            type: Type.STRING,\n            description: `The story narrative of Chapter ${chapterNumber}. Approximately 350-500 words written strictly in ${language} at ${cefrLevel} level, advancing the plot seamlessly.`,\n          },\n          vocabulary: {\n            type: Type.ARRAY,\n            items: {\n              type: Type.OBJECT,\n              properties: {\n                word: { type: Type.STRING, description: \'The terms, verbs, or expressions.\' },\n                partOfSpeech: { type: Type.STRING, description: \'Noun, Verb, Adjective, Idiom, etc.\' },\n                definition: { type: Type.STRING, description: \'English translation or explanation.\' },\n                contextSentence: { type: Type.STRING, description: \'The sentence it appears in or a custom illustrative sentence.\' },\n              },\n              required: [\'word\', \'partOfSpeech\', \'definition\', \'contextSentence\'],\n            },\n            description: `5 to 10 key terms from Chapter ${chapterNumber} for review.`,\n          },\n        },\n        required: [\'chapterTitle\', \'content\', \'vocabulary\'],\n      };\n\n      const summaryText = (previousChapters || [])\n        .map((ch: any) => `Chapter ${ch.chapterNumber}: \"${ch.title}\"\\nContent outline / excerpt: ${ch.content.substring(0, 300)}...`)\n        .join(\'\\n\\n\');\n\n      prompt = `Continue the story titled \"${storyTitle}\".\nLanguage: ${language}\nCEFR level: ${cefrLevel}\nGenre: ${genre}\nThis is Chapter ${chapterNumber} of ${totalChapters}.\n\nHere is the narrative flow of previous chapters for context:\n${summaryText}\n\nPlease write Chapter ${chapterNumber} of ${totalChapters}, ensuring a seamless continuation of the storyline. Make sure the difficulty is perfectly fitted for CEFR ${cefrLevel} level and that the word length remains around 350-500 words. Extract 5-10 key vocabulary terms as well.`;\n    }\n\n    const response = await ai.models.generateContent({\n      model: \'gemini-3.5-flash\',\n      contents: prompt,\n      config: {\n        systemInstruction,\n        responseMimeType: \'application/json\',\n        responseSchema,\n        temperature: 0.8,\n      },\n    });\n\n    const parsedData = JSON.parse(response.text || \'{}\');\n    return res.status(200).json(parsedData);\n  } catch (error: any) {\n    console.error(\'Error generating story chapter:\', error);\n    return res.status(500).json({ error: error.message || \'Error generating chapter.\' });\n  }\n});\n\n// Setup Vite Dev Server / Static files handlers\nasync function bootstrap() {\n  if (process.env.NODE_ENV !== \'production\') {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \'spa\',\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \'dist\');\n    app.use(express.static(distPath));\n    app.get(\'*\', (req, res) => {\n      res.sendFile(path.join(distPath, \'index.html\'));\n    });\n  }\n\n  app.listen(PORT, \'0.0.0.0\', () => {\n    console.log(`Server is running at http://localhost:${PORT}`);\n  });\n}\n\nbootstrap();\n"
    }
