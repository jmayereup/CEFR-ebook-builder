  file_change {
    absolute_path_uri: "file:///src/components/StoryConfigForm.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { motion } from \'motion/react\';\nimport { SUPPORTED_LANGUAGES, CEFR_LEVELS, GENRES } from \'../types\';\nimport { Globe, BookOpen, Layers, Sparkles, BookText } from \'lucide-react\';\n\ninterface StoryConfigFormProps {\n  onSubmit: (config: {\n    language: string;\n    cefrLevel: string;\n    genre: string;\n    totalChapters: number;\n    promptNotes: string;\n  }) => void;\n  isLoading: boolean;\n}\n\nexport default function StoryConfigForm({ onSubmit, isLoading }: StoryConfigFormProps) {\n  const [language, setLanguage] = useState(\'es\');\n  const [cefrLevel, setCefrLevel] = useState(\'B1\');\n  const [genre, setGenre] = useState(\'adventure\');\n  const [totalChapters, setTotalChapters] = useState(8);\n  const [promptNotes, setPromptNotes] = useState(\'\');\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    const selectedLanguage = SUPPORTED_LANGUAGES.find(l => l.code === language)?.name || \'Spanish\';\n    onSubmit({\n      language: selectedLanguage,\n      cefrLevel,\n      genre,\n      totalChapters,\n      promptNotes,\n    });\n  };\n\n  const selectedLevelObj = CEFR_LEVELS.find(l => l.code === cefrLevel);\n  const selectedLangObj = SUPPORTED_LANGUAGES.find(l => l.code === language);\n\n  return (\n    <motion.div\n      initial={{ opacity: 0, y: 15 }}\n      animate={{ opacity: 1, y: 0 }}\n      transition={{ duration: 0.4 }}\n      className=\"bg-white dark:bg-[#1e293b] p-6 rounded-2xl shadow-xl border border-slate-100 dark:border-slate-800\"\n    >\n      <div className=\"flex items-center gap-3 mb-6\">\n        <div className=\"p-3 bg-indigo-50 dark:bg-indigo-950/40 text-indigo-600 dark:text-indigo-400 rounded-xl\">\n          <BookText className=\"w-6 h-6\" />\n        </div>\n        <div>\n          <h2 className=\"text-xl font-semibold text-slate-800 dark:text-slate-100 font-sans tracking-tight\">Create a New Story</h2>\n          <p className=\"text-sm text-slate-500 dark:text-slate-400\">Configure your personalized language learning journey</p>\n        </div>\n      </div>\n\n      <form onSubmit={handleSubmit} className=\"space-y-6\">\n        {/* Language Selection */}\n        <div>\n          <label className=\"flex items-center gap-2 text-sm font-medium text-slate-700 dark:text-slate-300 mb-2\">\n            <Globe className=\"w-4 h-4 text-indigo-500\" />\n            Target Language\n          </label>\n          <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-2\">\n            {SUPPORTED_LANGUAGES.map((lang) => (\n              <button\n                key={lang.code}\n                type=\"button\"\n                onClick={() => setLanguage(lang.code)}\n                className={`flex flex-col items-center justify-center p-3 rounded-xl border text-center transition-all ${\n                  language === lang.code\n                    ? \'border-indigo-500 bg-indigo-50/50 dark:bg-indigo-950/20 text-indigo-600 dark:text-indigo-400 ring-2 ring-indigo-500/20\'\n                    : \'border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-600 bg-transparent text-slate-700 dark:text-slate-300\'\n                }`}\n              >\n                <span className=\"text-2xl mb-1\">{lang.flag}</span>\n                <span className=\"text-xs font-semibold\">{lang.name}</span>\n                <span className=\"text-[10px] text-slate-400 dark:text-slate-500\">{lang.nativeName}</span>\n              </button>\n            ))}\n          </div>\n        </div>\n\n        {/* CEFR Level & Description */}\n        <div>\n          <label className=\"flex items-center gap-2 text-sm font-medium text-slate-700 dark:text-slate-300 mb-2\">\n            <BookOpen className=\"w-4 h-4 text-indigo-500\" />\n            CEFR Level (Difficulty)\n          </label>\n          <div className=\"grid grid-cols-3 sm:grid-cols-6 gap-2 mb-2\">\n            {CEFR_LEVELS.map((level) => (\n              <button\n                key={level.code}\n                type=\"button\"\n                onClick={() => setCefrLevel(level.code)}\n                className={`py-2 px-3 rounded-xl border text-center text-sm font-semibold transition-all ${\n                  cefrLevel === level.code\n                    ? \'border-indigo-500 bg-indigo-50/50 dark:bg-indigo-950/20 text-indigo-600 dark:text-indigo-400 ring-2 ring-indigo-500/20\'\n                    : \'border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-600 text-slate-700 dark:text-slate-300\'\n                }`}\n              >\n                {level.code}\n              </button>\n            ))}\n          </div>\n          {selectedLevelObj && (\n            <motion.p\n              key={cefrLevel}\n              initial={{ opacity: 0, x: -5 }}\n              animate={{ opacity: 1, x: 0 }}\n              className=\"text-xs text-indigo-600/90 dark:text-indigo-400/90 ml-1 font-sans bg-indigo-50/30 dark:bg-slate-800/50 p-2.5 rounded-lg border border-indigo-100/30 dark:border-slate-700\"\n            >\n              <strong>Guide:</strong> {selectedLevelObj.description}\n            </motion.p>\n          )}\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n          {/* Genre selection */}\n          <div>\n            <label className=\"flex items-center gap-2 text-sm font-medium text-slate-700 dark:text-slate-300 mb-2\">\n              <Layers className=\"w-4 h-4 text-indigo-500\" />\n              Genre / Theme\n            </label>\n            <select\n              value={genre}\n              onChange={(e) => setGenre(e.target.value)}\n              className=\"w-full p-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-200 text-sm focus:border-indigo-500 focus:outline-none\"\n            >\n              {GENRES.map((g) => (\n                <option key={g.id} value={g.id}>\n                  {g.label}\n                </option>\n              ))}\n            </select>\n          </div>\n\n          {/* Chapters amount */}\n          <div>\n            <label className=\"flex items-center gap-2 text-sm font-medium text-slate-700 dark:text-slate-300 mb-2\">\n              <Layers className=\"w-4 h-4 text-indigo-500\" />\n              Story Length (Chapters)\n            </label>\n            <div className=\"flex items-center gap-3\">\n              <input\n                type=\"range\"\n                min=\"7\"\n                max=\"10\"\n                value={totalChapters}\n                onChange={(e) => setTotalChapters(parseInt(e.target.value))}\n                className=\"w-full accent-indigo-600 dark:accent-indigo-500\"\n              />\n              <span className=\"text-sm font-bold text-slate-800 dark:text-slate-100 font-mono bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-lg\">\n                {totalChapters} ch\n              </span>\n            </div>\n            <p className=\"text-[11px] text-slate-400 mt-1\">Each chapter contains ~400-500 words graded perfectly.</p>\n          </div>\n        </div>\n\n        {/* Custom notes */}\n        <div>\n          <label className=\"flex items-center gap-2 text-sm font-medium text-slate-700 dark:text-slate-300 mb-2\">\n            <Sparkles className=\"w-4 h-4 text-indigo-500\" />\n            Story Prompt & Custom Ideas (Optional)\n          </label>\n          <textarea\n            placeholder=\"e.g., A time traveler named Leo lands in Paris 1889 and meets a mysterious clockmaker. Or: focus on food and dining vocabulary.\"\n            value={promptNotes}\n            onChange={(e) => setPromptNotes(e.target.value)}\n            rows={3}\n            className=\"w-full p-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-200 text-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500\"\n          />\n        </div>\n\n        {/* Start button */}\n        <button\n          type=\"submit\"\n          disabled={isLoading}\n          className=\"w-full flex items-center justify-center gap-2 py-3.5 px-4 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 disabled:bg-slate-400 disabled:dark:bg-slate-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white font-semibold text-sm rounded-xl transition-colors shadow-lg shadow-indigo-600/10 dark:shadow-none cursor-pointer\"\n        >\n          {isLoading ? (\n            <div className=\"flex items-center gap-2\">\n              <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\"></div>\n              <span>Crafting Plot & Loading Chapter 1...</span>\n            </div>\n          ) : (\n            <>\n              <Sparkles className=\"w-4 h-4\" />\n              <span>Generate Chapter 1 & Begin Story!</span>\n            </>\n          )}\n        </button>\n      </form>\n    </motion.div>\n  );\n}\n"
    }
