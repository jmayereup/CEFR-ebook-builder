    replacement_chunks {
      replacement_content: "import { useState } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Chapter, Story } from \'../types\';\nimport { BookOpen, Type, ZoomIn, ZoomOut, ChevronRight, CheckCircle2, AlertCircle } from \'lucide-react\';\n\ninterface ReaderPanelProps {\n  story: Story;\n  activeChapterIndex: number;\n  onSelectChapter: (index: number) => void;\n  onGenerateNextChapter: () => void;\n  isLoadingNext: boolean;\n  isAutoGeneratingRemaining: boolean;\n  onAutoGenerateAll: () => void;\n}\n\nexport default function ReaderPanel({\n  story,\n  activeChapterIndex,\n  onSelectChapter,\n  onGenerateNextChapter,\n  isLoadingNext,\n  isAutoGeneratingRemaining,\n  onAutoGenerateAll,\n}: ReaderPanelProps) {\n  const [fontSize, setFontSize] = useState<number>(18); // default comfortable reading size\n  const [useSerif, setUseSerif] = useState<boolean>(true); // serif is traditional for books\n\n  const activeChapter: Chapter | undefined = story.chapters[activeChapterIndex];\n  const totalChaptersCount = story.totalChapters;\n  const currentChaptersLoaded = story.chapters.length;\n  const isFinishedStory = currentChaptersLoaded >= totalChaptersCount && activeChapterIndex === currentChaptersLoaded - 1;\n\n  if (!activeChapter) {\n    return (\n      <div className=\"flex flex-col items-center justify-center p-12 text-slate-400\">\n        <AlertCircle className=\"w-12 h-12 mb-4 text-slate-300 animate-pulse\" />\n        <p className=\"text-slate-500\">No chapter active. Select or generate a chapter to begin reading.</p>\n      </div>\n    );\n  }\n\n  // Split chapter content into clean paragraphs for rendering\n  const paragraphs = activeChapter.content\n    .split(/\\n+/)\n    .map((p) => p.trim())\n    .filter((p) => p.length > 0);\n\n  return (\n    <div className=\"grid grid-cols-1 lg:grid-cols-4 gap-6\">\n      {/* Chapter navigation sidebar */}\n      <div className=\"lg:col-span-1 bg-white dark:bg-[#1e293b] p-4 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-sm space-y-4 h-fit\">\n        <h3 className=\"text-sm font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider font-mono\">Chapters</h3>\n        <nav className=\"flex flex-col gap-1 max-h-[300px] lg:max-h-none overflow-y-auto\">\n          {Array.from({ length: totalChaptersCount }).map((_, i) => {\n            const index = i;\n            const chapterNum = index + 1;\n            const isLoaded = index < story.chapters.length;\n            const isCurrent = index === activeChapterIndex;\n\n            return (\n              <button\n                key={index}\n                disabled={!isLoaded && !isLoadingNext}\n                onClick={() => onSelectChapter(index)}\n                className={`flex items-center justify-between w-full p-2.5 rounded-xl font-sans text-xs text-left transition-all ${\n                  isCurrent\n                    ? \'bg-indigo-600 text-white font-semibold\'\n                    : isLoaded\n                    ? \'hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300\'\n                    : \'text-slate-400 dark:text-slate-600 cursor-not-allowed bg-slate-50/50 dark:bg-slate-900/10\'\n                }`}\n              >\n                <div className=\"flex items-center gap-2\">\n                  <span className={`w-5 h-5 rounded-md flex items-center justify-center border font-mono text-[10px] ${\n                    isCurrent \n                      ? \'border-indigo-400 bg-indigo-500 text-white\' \n                      : \'border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400\'\n                  }`}>\n                    {chapterNum}\n                  </span>\n                  <span className=\"truncate max-w-[120px] lg:max-w-[150px]\">\n                    {isLoaded ? story.chapters[index].title : `Chapter ${chapterNum}`}\n                  </span>\n                </div>\n                {isLoaded && <CheckCircle2 className={`w-3.5 h-3.5 ${isCurrent ? \'text-white\' : \'text-emerald-500\'}`} />}\n              </button>\n            );\n          })}\n        </nav>\n\n        {/* Generate triggers */}\n        <div className=\"pt-4 border-t border-slate-100 dark:border-slate-800 space-y-2\">\n          {currentChaptersLoaded < totalChaptersCount ? (\n            <>\n              <button\n                disabled={isLoadingNext || isAutoGeneratingRemaining}\n                onClick={onGenerateNextChapter}\n                className=\"w-full flex items-center justify-center gap-1.5 py-2.5 px-3 bg-indigo-50 hover:bg-indigo-100 dark:bg-indigo-950/30 dark:hover:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 text-xs font-semibold rounded-xl transition-colors cursor-pointer\"\n              >\n                {isLoadingNext && !isAutoGeneratingRemaining ? (\n                  <>\n                    <div className=\"w-3.5 h-3.5 border-2 border-indigo-500/20 border-t-indigo-500 rounded-full animate-spin\"></div>\n                    <span>Generating Ch {currentChaptersLoaded + 1}...</span>\n                  </>\n                ) : (\n                  <>\n                    <ChevronRight className=\"w-4 h-4\" />\n                    <span>Generate Chapter {currentChaptersLoaded + 1}</span>\n                  </>\n                )}\n              </button>\n\n              <button\n                disabled={isLoadingNext || isAutoGeneratingRemaining}\n                onClick={onAutoGenerateAll}\n                className=\"w-full py-2 px-3 border border-dashed border-indigo-200 dark:border-indigo-800/60 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-medium rounded-xl transition-colors cursor-pointer\"\n              >\n                {isAutoGeneratingRemaining ? (\n                  <span className=\"flex items-center justify-center gap-1.5 text-indigo-500\">\n                    <div className=\"w-3.5 h-3.5 border-2 border-indigo-500/20 border-t-indigo-500 rounded-full animate-spin\"></div>\n                    Auto-writing story... ({currentChaptersLoaded}/{totalChaptersCount})\n                  </span>\n                ) : (\n                  <span>Auto-Write Remaining Chapters</span>\n                )}\n              </button>\n            </>\n          ) : (\n            <div className=\"flex items-center gap-1.5 text-emerald-600 dark:text-emerald-400 font-sans text-xs bg-emerald-50 dark:bg-emerald-950/20 p-2.5 rounded-xl border border-emerald-100/50 dark:border-emerald-950/20\">\n              <CheckCircle2 className=\"w-4 h-4 shrink-0\" />\n              <span>Full story successfully loaded!</span>\n            </div>\n          )}\n        </div>\n      </div>\n\n      {/* Main Chapter Content and Reading Area */}\n      <div className=\"lg:col-span-3 space-y-6\">\n        <motion.div\n          key={activeChapter.chapterNumber}\n          initial={{ opacity: 0, x: 10 }}\n          animate={{ opacity: 1, x: 0 }}\n          transition={{ duration: 0.3 }}\n          className=\"bg-[#FAF9F6] dark:bg-[#111827] text-slate-800 dark:text-slate-200 p-6 md:p-8 rounded-2xl border border-slate-100 dark:border-slate-800/80 shadow-md relative\"\n        >\n          {/* Reader toolbar settings */}\n          <div className=\"flex flex-wrap items-center justify-between gap-4 border-b border-slate-200/50 dark:border-slate-800 pb-4 mb-6\">\n            <div className=\"flex items-center gap-2\">\n              <BookOpen className=\"w-4 h-4 text-indigo-500\" />\n              <span className=\"text-xs font-mono text-slate-500 dark:text-slate-400\">\n                Chapter {activeChapter.chapterNumber} of {totalChaptersCount}\n              </span>\n            </div>\n\n            <div className=\"flex items-center gap-2.5\">\n              {/* Serif/Sans Toggle */}\n              <button\n                onClick={() => setUseSerif(!useSerif)}\n                title=\"Toggle Reading Font\"\n                className={`p-1.5 rounded-lg border transition-all cursor-pointer ${\n                  useSerif\n                    ? \'bg-slate-100 dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-indigo-600 dark:text-indigo-400\'\n                    : \'border-slate-200 dark:border-slate-800 text-slate-500 hover:bg-slate-55 dark:hover:bg-slate-800\'\n                }`}\n              >\n                <Type className=\"w-4 h-4\" />\n              </button>\n\n              <div className=\"h-4 w-px bg-slate-200 dark:bg-slate-800\"></div>\n\n              {/* Font Size controls */}\n              <div className=\"flex items-center gap-1 bg-slate-100/60 dark:bg-slate-800/60 rounded-xl p-1 border border-slate-200/40 dark:border-slate-800\">\n                <button\n                  onClick={() => setFontSize(Math.max(14, fontSize - 1))}\n                  disabled={fontSize <= 14}\n                  className=\"p-1 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 disabled:opacity-40 cursor-pointer\"\n                >\n                  <ZoomOut className=\"w-3.5 h-3.5\" />\n                </button>\n                <span className=\"text-[10px] font-sans font-semibold text-slate-500 w-8 text-center select-none\">\n                  {fontSize}px\n                </span>\n                <button\n                  onClick={() => setFontSize(Math.min(26, fontSize + 1))}\n                  disabled={fontSize >= 26}\n                  className=\"p-1 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 disabled:opacity-40 cursor-pointer\"\n                >\n                  <ZoomIn className=\"w-3.5 h-3.5\" />\n                </button>\n              </div>\n            </div>\n          </div>\n\n          {/* Chapter header */}\n          <div className=\"mb-6\">\n            <h2 className=\"text-2xl font-bold font-serif text-slate-900 dark:text-white tracking-tight leading-tight\">\n              {activeChapter.title}\n            </h2>\n            <div className=\"h-1 w-12 bg-indigo-500 rounded mt-3\"></div>\n          </div>\n\n          {/* Actual reading paper content */}\n          <div\n            className={`space-y-6 leading-relaxed select-text ${\n              useSerif ? \'font-serif\' : \'font-sans\'\n            }`}\n            style={{ fontSize: `${fontSize}px` }}\n          >\n            {paragraphs.map((p, idx) => (\n              <p key={idx} className=\"indent-4 md:indent-6 text-justify\">\n                {p}\n              </p>\n            ))}\n          </div>\n        </motion.div>\n\n        {/* Dynamic Vocabulary Builder list under selection */}\n        {activeChapter.vocabulary && activeChapter.vocabulary.length > 0 && (\n          <motion.div\n            initial={{ opacity: 0, y: 10 }}\n            animate={{ opacity: 1, y: 0 }}\n            className=\"bg-white dark:bg-[#1e293b] p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800\"\n          >\n            <div className=\"flex items-center justify-between mb-4\">\n              <h3 className=\"font-semibold text-slate-800 dark:text-slate-100 font-sans text-sm flex items-center gap-1.5\">\n                <span className=\"w-2.5 h-2.5 bg-indigo-500 rounded-full animate-pulse\"></span>\n                Key Vocabulary Terms Extracted\n              </h3>\n              <span className=\"text-[10px] font-mono text-slate-400 px-2.5 py-0.5 rounded-full bg-slate-100 dark:bg-slate-800 leading-none\">\n                {activeChapter.vocabulary.length} terms in Chapter {activeChapter.chapterNumber}\n              </span>\n            </div>\n\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n              {activeChapter.vocabulary.map((vocab, index) => (\n                <div\n                  key={index}\n                  className=\"p-3.5 rounded-xl border border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/10 hover:border-slate-200 dark:hover:border-slate-700 transition-colors\"\n                >\n                  <div className=\"flex items-baseline justify-between gap-1 mb-1\">\n                    <span className=\"font-serif font-bold text-slate-900 dark:text-slate-100 text-base\">\n                      {vocab.word}\n                    </span>\n                    <span className=\"text-[10px] uppercase font-mono tracking-wider font-semibold text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-950/20 px-1.5 py-0.5 rounded\">\n                      {vocab.partOfSpeech}\n                    </span>\n                  </div>\n                  <p className=\"text-xs font-sans text-slate-600 dark:text-slate-300 font-semibold mb-2\">\n                    {vocab.definition}\n                  </p>\n                  <div className=\"bg-white dark:bg-slate-850 p-2 rounded-lg border border-slate-100/50 dark:border-slate-800 text-xs text-slate-500 dark:text-slate-400 italic font-mono leading-normal\">\n                    \"{vocab.contextSentence}\"\n                  </div>\n                </div>\n              ))}\n            </div>\n          </motion.div>\n        )}\n      </div>\n    </div>\n  );\n}\n"
    }
