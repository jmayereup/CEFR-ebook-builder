    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Story, VocabularyTerm } from \'../types\';\nimport { Gamepad2, Layers, Shuffle, CheckCircle, RefreshCw, XCircle } from \'lucide-react\';\n\ninterface VocabularyPracticeProps {\n  story: Story;\n}\n\nexport default function VocabularyPractice({ story }: VocabularyPracticeProps) {\n  const [activeTab, setActiveTab] = useState<\'flashcards\' | \'match\'>(\'flashcards\');\n\n  // Collect all vocab words from all currently decoded story chapters\n  const allVocab: VocabularyTerm[] = story.chapters.reduce((accum: VocabularyTerm[], ch) => {\n    if (ch.vocabulary) {\n      accum.push(...ch.vocabulary);\n    }\n    return accum;\n  }, []);\n\n  if (allVocab.length === 0) {\n    return (\n      <div className=\"bg-white dark:bg-[#1e293b] p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 text-center text-slate-500\">\n        <Layers className=\"w-12 h-12 text-slate-300 dark:text-slate-600 mx-auto mb-3 animate-bounce\" />\n        <p className=\"font-medium text-slate-700 dark:text-slate-300\">No Vocabulary Terms Available Yet</p>\n        <p className=\"text-xs text-slate-400 mt-1\">Please start or load a story with some chapters to unlock vocabulary builders!</p>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Tab navigation */}\n      <div className=\"flex bg-slate-100 dark:bg-slate-800 p-1 rounded-xl w-fit\">\n        <button\n          onClick={() => setActiveTab(\'flashcards\')}\n          className={`flex items-center gap-1.5 px-4 py-2 text-xs font-semibold rounded-lg transition-all cursor-pointer ${\n            activeTab === \'flashcards\'\n              ? \'bg-white dark:bg-slate-700 text-indigo-600 dark:text-indigo-400 shadow-sm\'\n              : \'text-slate-600 dark:text-slate-400 hover:text-slate-805\'\n          }`}\n        >\n          <Layers className=\"w-3.5 h-3.5\" />\n          Interactive Flashcards ({allVocab.length})\n        </button>\n        <button\n          onClick={() => setActiveTab(\'match\')}\n          className={`flex items-center gap-1.5 px-4 py-2 text-xs font-semibold rounded-lg transition-all cursor-pointer ${\n            activeTab === \'match\'\n              ? \'bg-white dark:bg-slate-700 text-indigo-600 dark:text-indigo-400 shadow-sm\'\n              : \'text-slate-600 dark:text-slate-400 hover:text-slate-805\'\n          }`}\n        >\n          <Gamepad2 className=\"w-3.5 h-3.5\" />\n          Vocab Matching Game\n        </button>\n      </div>\n\n      <AnimatePresence mode=\"wait\">\n        {activeTab === \'flashcards\' ? (\n          <FlashcardsDeck key=\"flashcards\" terms={allVocab} />\n        ) : (\n          <MatchingGame key=\"match\" terms={allVocab} />\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}\n\n/* ==========================================================================\n   FLASHCARDS SUB-COMPONENT\n   ========================================================================== */\nfunction FlashcardsDeck({ terms }: { terms: VocabularyTerm[] }) {\n  const [currentIndex, setCurrentIndex] = useState(0);\n  const [isFlipped, setIsFlipped] = useState(false);\n  const [knownCount, setKnownCount] = useState(0);\n\n  const activeTerm = terms[currentIndex % terms.length];\n\n  const handleNext = (known: boolean) => {\n    if (known) {\n      setKnownCount((c) => c + 1);\n    }\n    setIsFlipped(false);\n    setTimeout(() => {\n      setCurrentIndex((prev) => (prev + 1) % terms.length);\n    }, 150);\n  };\n\n  const handleReset = () => {\n    setCurrentIndex(0);\n    setKnownCount(0);\n    setIsFlipped(false);\n  };\n\n  return (\n    <motion.div\n      initial={{ opacity: 0, scale: 0.98 }}\n      animate={{ opacity: 1, scale: 1 }}\n      exit={{ opacity: 0, scale: 0.98 }}\n      className=\"max-w-md mx-auto space-y-6 flex flex-col items-center\"\n    >\n      {/* Flashcard container with 3D Flip */}\n      <div \n        onClick={() => setIsFlipped(!isFlipped)}\n        className=\"w-full h-72 perspective cursor-pointer\"\n      >\n        <div className={`w-full h-full relative transition-all duration-500 preserve-3d ${isFlipped ? \'rotate-y-180\' : \'\'}`}>\n          \n          {/* FRONT Side: Target Word */}\n          <div className=\"absolute inset-0 w-full h-full bg-white dark:bg-[#1e293b] rounded-3xl p-6 shadow-xl border border-slate-100 dark:border-slate-850 flex flex-col justify-between backface-hidden\">\n            <span className=\"text-[10px] font-mono text-slate-400 dark:text-slate-500 tracking-wider\">\n              Card {currentIndex + 1} of {terms.length} \342\200\242 FRONT\n            </span>\n            <div className=\"text-center py-6\">\n              <h2 className=\"text-3xl font-serif font-black text-slate-800 dark:text-slate-100 tracking-tight select-none\">\n                {activeTerm.word}\n              </h2>\n              <span className=\"text-[10px] uppercase font-mono bg-indigo-50 dark:bg-indigo-950/20 text-indigo-600 dark:text-indigo-400 font-bold px-2.5 py-1 rounded mt-3 inline-block select-none\">\n                {activeTerm.partOfSpeech}\n              </span>\n            </div>\n            <p className=\"text-[10px] text-center text-slate-400 select-none animate-pulse\">\n              Click to Flip\n            </p>\n          </div>\n\n          {/* BACK Side: English definition and context */}\n          <div className=\"absolute inset-0 w-full h-full bg-indigo-50/20 dark:bg-[#0f172a] rounded-3xl p-6 shadow-xl border border-indigo-100/50 dark:border-slate-800 flex flex-col justify-between backface-hidden rotate-y-180\">\n            <span className=\"text-[10px] font-mono text-indigo-500 dark:text-indigo-400 tracking-wider\">\n              Card {currentIndex + 1} of {terms.length} \342\200\242 BACK (Translation)\n            </span>\n            <div className=\"space-y-4 text-center\">\n              <div>\n                <h3 className=\"text-lg font-bold text-slate-900 dark:text-slate-100 leading-tight\">\n                  {activeTerm.definition}\n                </h3>\n                <span className=\"text-[9px] uppercase font-mono tracking-wider font-semibold text-slate-400\">\n                  {activeTerm.word} ({activeTerm.partOfSpeech})\n                </span>\n              </div>\n              <div className=\"bg-white/80 dark:bg-slate-900 p-3 rounded-2xl border border-indigo-100/30 dark:border-slate-800 text-xs text-slate-600 dark:text-slate-300 italic font-serif leading-relaxed max-h-[85px] overflow-y-auto\">\n                \"{activeTerm.contextSentence}\"\n              </div>\n            </div>\n            <p className=\"text-[10px] text-center text-slate-400 select-none\">\n              Click to Flip BACK\n            </p>\n          </div>\n\n        </div>\n      </div>\n\n      {/* Control Buttons */}\n      <div className=\"flex gap-4 w-full select-none\">\n        <button\n          onClick={() => handleNext(false)}\n          className=\"flex-1 py-3 px-4 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-750 text-slate-750 dark:text-slate-350 text-xs font-semibold rounded-2xl transition-colors cursor-pointer\"\n        >\n          Still Practicing \360\237\224\204\n        </button>\n        <button\n          onClick={() => handleNext(true)}\n          className=\"flex-1 py-3 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold rounded-2xl transition-all shadow-md shadow-indigo-600/10 cursor-pointer\"\n        >\n          Got It! \360\237\221\215\n        </button>\n      </div>\n\n      {/* Progress status indicators */}\n      <div className=\"flex justify-between w-full text-xs font-semibold text-slate-500 dark:text-slate-400 select-none\">\n        <span>Score: {knownCount}/{currentIndex} words</span>\n        <button \n          onClick={handleReset}\n          className=\"text-indigo-600 hover:text-indigo-700 flex items-center gap-1 leading-none font-sans cursor-pointer\"\n        >\n          <RefreshCw className=\"w-3 h-3\" />\n          Reset Stats\n        </button>\n      </div>\n    </motion.div>\n  );\n}\n\n/* ==========================================================================\n   WORD MATCHING GAME SUB-COMPONENT\n   ========================================================================== */\ninterface ShuffledItem {\n  id: string;\n  word: string;\n}\n\ninterface SelectedNode {\n  type: \'word\' | \'definition\';\n  termId: string;\n}\n\nfunction MatchingGame({ terms }: { terms: VocabularyTerm[] }) {\n  const [subset, setSubset] = useState<VocabularyTerm[]>([]);\n  const [shuffledWords, setShuffledWords] = useState<ShuffledItem[]>([]);\n  const [shuffledDefs, setShuffledDefs] = useState<ShuffledItem[]>([]);\n\n  const [selectedWord, setSelectedWord] = useState<string | null>(null);\n  const [selectedDef, setSelectedDef] = useState<string | null>(null);\n\n  const [matchedIds, setMatchedIds] = useState<Set<string>>(new Set());\n  const [failedPairs, setFailedPairs] = useState<{ wordId: string; defId: string } | null>(null);\n\n  // Initialize a round of the game (slice 5 words)\n  const initializeRound = () => {\n    // Shuffle the parent array\n    const shuffledTerms = [...terms].sort(() => 0.5 - Math.random());\n    const selected = shuffledTerms.slice(0, Math.min(5, shuffledTerms.length));\n\n    const words = selected.map((t) => ({ id: t.word, word: t.word }));\n    const defs = selected.map((t) => ({ id: t.word, word: t.definition }));\n\n    // Shuffle each columns\n    setShuffledWords([...words].sort(() => 0.5 - Math.random()));\n    setShuffledDefs([...defs].sort(() => 0.5 - Math.random()));\n\n    setSubset(selected);\n    setSelectedWord(null);\n    setSelectedDef(null);\n    setMatchedIds(new Set());\n    setFailedPairs(null);\n  };\n\n  useEffect(() => {\n    initializeRound();\n  }, [terms]);\n\n  // Click handler\n  const handleWordSelect = (id: string) => {\n    if (matchedIds.has(id)) return;\n    setFailedPairs(null);\n\n    if (id === selectedWord) {\n      setSelectedWord(null);\n    } else {\n      setSelectedWord(id);\n      checkMatch(id, selectedDef);\n    }\n  };\n\n  const handleDefSelect = (id: string) => {\n    if (matchedIds.has(id)) return;\n    setFailedPairs(null);\n\n    if (id === selectedDef) {\n      setSelectedDef(null);\n    } else {\n      setSelectedDef(id);\n      checkMatch(selectedWord, id);\n    }\n  };\n\n  const checkMatch = (wordId: string | null, defId: string | null) => {\n    if (wordId && defId) {\n      if (wordId === defId) {\n        // Success match!\n        setMatchedIds(new Set([...matchedIds, wordId]));\n        setSelectedWord(null);\n        setSelectedDef(null);\n      } else {\n        // Fail match\n        setFailedPairs({ wordId, defId });\n        setSelectedWord(null);\n        setSelectedDef(null);\n      }\n    }\n  };\n\n  return (\n    <motion.div\n      initial={{ opacity: 0, scale: 0.98 }}\n      animate={{ opacity: 1, scale: 1 }}\n      exit={{ opacity: 0, scale: 0.98 }}\n      className=\"bg-white dark:bg-[#1e293b] p-6 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-sm space-y-6\"\n    >\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h3 className=\"font-semibold text-slate-800 dark:text-slate-100 text-sm\">Matching Exercise</h3>\n          <p className=\"text-xs text-slate-500\">Connect the vocabulary words with their correct English definitions.</p>\n        </div>\n        <button\n          onClick={initializeRound}\n          className=\"p-2 bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-750 text-indigo-600 dark:text-indigo-400 rounded-xl transition-all cursor-pointer\"\n          title=\"Shuffled / Load New Board\"\n        >\n          <Shuffle className=\"w-4 h-4\" />\n        </button>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 relative select-none\">\n        \n        {/* Words Column */}\n        <div className=\"space-y-2\">\n          <span className=\"text-[10px] uppercase font-mono tracking-wider font-semibold text-slate-400 block mb-1\">Target Language Word</span>\n          {shuffledWords.map((item) => {\n            const isMatched = matchedIds.has(item.id);\n            const isSelected = selectedWord === item.id;\n            const isFailed = failedPairs?.wordId === item.id;\n\n            return (\n              <button\n                key={item.id}\n                onClick={() => handleWordSelect(item.id)}\n                className={`w-full p-4 rounded-xl text-left border text-sm transition-all font-serif flex items-center justify-between cursor-pointer ${\n                  isMatched\n                    ? \'border-emerald-200 bg-emerald-50/40 text-slate-400 dark:border-emerald-950/20 dark:bg-emerald-950/10 cursor-not-allowed font-medium\'\n                    : isFailed\n                    ? \'border-rose-400 bg-rose-50 text-rose-700 dark:border-rose-950/20 dark:bg-rose-950/10 animate-shake\'\n                    : isSelected\n                    ? \'border-indigo-500 bg-indigo-50 text-indigo-700 dark:bg-indigo-950/20 font-bold shadow-md\'\n                    : \'border-slate-200 dark:border-slate-800 hover:border-indigo-300 dark:hover:border-slate-700 bg-transparent text-slate-800 dark:text-slate-200 font-semibold shadow-sm\'\n                }`}\n              >\n                <span>{item.word}</span>\n                {isMatched && <CheckCircle className=\"w-4 h-4 text-emerald-500 shrink-0\" />}\n                {isFailed && <XCircle className=\"w-4 h-4 text-rose-500 shrink-0\" />}\n              </button>\n            );\n          })}\n        </div>\n\n        {/* Definitions Column */}\n        <div className=\"space-y-2\">\n          <span className=\"text-[10px] uppercase font-mono tracking-wider font-semibold text-slate-400 block mb-1\">English Definition</span>\n          {shuffledDefs.map((item) => {\n            const isMatched = matchedIds.has(item.id);\n            const isSelected = selectedDef === item.id;\n            const isFailed = failedPairs?.defId === item.id;\n\n            return (\n              <button\n                key={item.id}\n                onClick={() => handleDefSelect(item.id)}\n                className={`w-full p-4 rounded-xl text-left border text-sm transition-all font-sans flex items-center justify-between cursor-pointer ${\n                  isMatched\n                    ? \'border-emerald-200 bg-emerald-50/40 text-slate-400 dark:border-emerald-950/20 dark:bg-emerald-950/10 cursor-not-allowed font-medium\'\n                    : isFailed\n                    ? \'border-rose-400 bg-rose-50 text-rose-700 dark:border-rose-950/20 dark:bg-rose-950/10\'\n                    : isSelected\n                    ? \'border-indigo-500 bg-indigo-50 text-indigo-700 dark:bg-indigo-950/20 font-bold shadow-md\'\n                    : \'border-slate-200 dark:border-slate-800 hover:border-indigo-300 dark:hover:border-slate-700 bg-transparent text-slate-800 dark:text-slate-200 font-semibold shadow-sm\'\n                }`}\n              >\n                <span className=\"line-clamp-1 text-xs\">{item.word}</span>\n                {isMatched && <CheckCircle className=\"w-4 h-4 text-emerald-500 shrink-0\" />}\n                {isFailed && <XCircle className=\"w-4 h-4 text-rose-500 shrink-0\" />}\n              </button>\n            );\n          })}\n        </div>\n\n      </div>\n\n      {matchedIds.size === subset.length && subset.length > 0 && (\n        <motion.div\n          initial={{ scale: 0.95, opacity: 0 }}\n          animate={{ scale: 1, opacity: 1 }}\n          className=\"bg-emerald-50/80 dark:bg-emerald-950/20 border border-emerald-200/50 dark:border-emerald-950/20 p-4 rounded-2xl flex flex-col sm:flex-row items-center justify-between gap-3 text-emerald-700 dark:text-emerald-400\"\n        >\n          <div className=\"flex items-center gap-2\">\n            <CheckCircle className=\"w-5 h-5 shrink-0\" />\n            <span className=\"text-sm font-semibold\">Incredible work! You matched all pairs in this set!</span>\n          </div>\n          <button\n            onClick={initializeRound}\n            className=\"py-1.5 px-4 bg-emerald-600 hover:bg-emerald-700 font-semibold text-white text-xs rounded-xl transition-all cursor-pointer\"\n          >\n            Load Next Board \360\237\224\204\n          </button>\n        </motion.div>\n      )}\n    </motion.div>\n  );\n}\n"
    }
    diff {
      unified_diff {
